# Supabase Configuration
# Replace these with your own Supabase project details
EXPO_PUBLIC_SUPABASE_URL=your-project-url-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# The public key is exposed to the browser; the private key is an Edge Function secret only.
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
