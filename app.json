{
  "expo": {
    "name": "TrustFlow",
    "slug": "TrustFlow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "TrustFlow",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "TrustFlow sends you task and pipeline notifications."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#1a1a2e",
          "androidMode": "default",
          "androidCollapsedTitle": "TrustFlow",
          "sounds": [],
          "androidChannels": [
            {
              "name": "default",
              "importance": "HIGH",
              "sound": true,
              "vibrate": true,
              "badge": true
            }
          ]
        }
      ]
    ]
  }
}
